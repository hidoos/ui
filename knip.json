{
	"$schema": "https://unpkg.com/knip@5/schema.json",
	"paths": {
		"@/*": ["src/*"]
	},
	"ignoreDependencies": [
		"@tanstack/react-table",
		"@tanstack/react-query",
		"@vitest/coverage-v8"
	],
	"ignoreExportsUsedInFile": false,
	"project": ["src/**/*.{ts,tsx}"],
	"ignoreIssues": {
		"src/components/ui/**": ["exports", "types"],
		"src/foundation/lib/api/api-gen.ts": ["exports", "types"]
	}
}
